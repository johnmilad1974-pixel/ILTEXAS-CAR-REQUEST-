rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidReservation(data) {
      return data.requesterName is string && data.requesterName.size() > 0 && data.requesterName.size() <= 100
          && data.carId is string && data.carId.size() > 0
          && data.startDate is number && data.startDate > 0
          && data.endDate is number && data.endDate > data.startDate
          && data.requestDate is number
          && (data.status == 'approved' || data.status == 'pending' || data.status == 'cancelled');
    }

    match /reservations/{reservationId} {
      // Allow read for everyone
      allow read: if true;

      // Allow create: anyone with the link can create, keeping validation for security
      allow create: if isValidId(reservationId)
                   && isValidReservation(incoming())
                   && incoming().requestDate <= request.time.toMillis() + 60000;

      // Allow update: anyone with the link can update, data must remain valid
      allow update: if isValidReservation(incoming())
                   && incoming().carId == existing().carId;

      // Allow delete: anyone with the link can delete
      allow delete: if true;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
